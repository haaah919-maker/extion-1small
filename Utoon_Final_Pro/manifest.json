{
  "manifest_version": 3,
  "name": "Utoon Ultimate Pro Max",
  "version": "1.5",
  "description": "The Ultimate Manga Reading Experience for Utoon.net",
  "permissions": [
    "storage",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "https://utoon.net/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://utoon.net/*"],
      "js": ["content_script.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/*.png", "jszip.min.js", "jspdf.min.js", "bundle_reader.js", "bulk_helper.js"],
      "matches": ["https://utoon.net/*"]
    }
  ]
}
