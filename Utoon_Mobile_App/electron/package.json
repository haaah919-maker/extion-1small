{
  "name": "utoon-pro-desktop",
  "productName": "Utoon Ultimate Pro",
  "version": "2.2.0",
  "description": "Utoon Ultimate Pro Unified Desktop Reader",
  "main": "src/index.js",
  "scripts": {
    "start": "electron .",
    "obfuscate": "javascript-obfuscator assets/reader_logic.js --output assets/reader_logic.js",
    "dist": "npm run obfuscate && electron-builder --win",
    "build": "npm install && npm run dist"
  },
  "devDependencies": {
    "electron": "^25.0.0",
    "electron-builder": "^24.4.0",
    "javascript-obfuscator": "^4.1.0"
  },
  "build": {
    "appId": "com.utoon.desktop",
    "win": { "target": "portable", "icon": "assets/icon.png" },
    "directories": { "output": "dist" },
    "files": ["src/**/*", "assets/**/*"]
  }
}
