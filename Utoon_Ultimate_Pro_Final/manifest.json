{
  "manifest_version": 3,
  "name": "Utoon Ultimate Pro Unified",
  "version": "2.2",
  "description": "Unified Reader with Effects, Themes, and Cross-Platform Support.",
  "permissions": ["activeTab", "scripting", "tabs", "storage"],
  "host_permissions": ["https://utoon.net/*"],
  "background": { "service_worker": "background.js" },
  "action": {
    "default_popup": "popup.html",
    "default_icon": { "128": "icons/icon.png" }
  },
  "icons": { "128": "icons/icon.png" },
  "web_accessible_resources": [
    { "resources": ["assets/*"], "matches": ["https://utoon.net/*"] }
  ]
}
