{
  "manifest_version": 3,
  "name": "Utoon Ultimate Pro",
  "version": "1.4",
  "description": "Ultimate Reader with Enhanced Navigation, Visual Cues, and Themes.",
  "permissions": ["activeTab", "scripting", "tabs", "storage"],
  "host_permissions": ["https://utoon.net/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://utoon.net/*"],
      "js": ["fix_links.js"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "128": "icons/icon.png"
    }
  },
  "icons": {
    "128": "icons/icon.png"
  }
}
