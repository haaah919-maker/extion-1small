{
  "manifest_version": 3,
  "name": "Utoon Reader Pro",
  "version": "2.0",
  "description": "free chapters & downloaad & fun. ( discord: @threads. )",
  "permissions": ["activeTab", "scripting", "tabs", "storage"],
  "host_permissions": ["https://utoon.net/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "web_accessible_resources": [
    {
      "resources": ["assets/bg.png", "assets/bg2.png"],
      "matches": ["https://utoon.net/*"]
    }
  ]
}
