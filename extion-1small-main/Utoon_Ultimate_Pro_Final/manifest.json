{
  "manifest_version": 3,
  "name": "Utoon Ultimate Pro",
  "version": "3.0",
  "description": "Ultimate Manga Reader with Themes, Effects, Auto-Scroll, ZIP/PDF Download.",
  "permissions": ["activeTab", "scripting", "tabs", "storage"],
  "host_permissions": ["https://utoon.net/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://utoon.net/*"],
      "js": ["fix_links.js"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "128": "icons/icon.png"
    }
  },
  "icons": {
    "128": "icons/icon.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["assets/bg.png", "assets/bg2.png"],
      "matches": ["https://utoon.net/*"]
    }
  ]
}
